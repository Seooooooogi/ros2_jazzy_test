# ros2_jazzy_test — Environment variables template
#
# 사용법:
#   1. cp .env.example .env
#   2. .env 안의 placeholder를 실제 값으로 교체
#   3. 절대 .env를 커밋하지 말 것 (.gitignore에 등록됨)
#
# 스크립트에서 로드 패턴:
#   set -a; source .env; set +a
#   : "${OPENAI_API_KEY:?OPENAI_API_KEY가 설정되지 않았습니다}"

# === API Keys (a04-voice-precheck.sh 점검 / 음성 컨테이너가 runtime mount) ===
# OPENAI_API_KEY=

# === Phase 4 컨테이너 (containers/build-all.sh / docker-compose.yml) ===
# DOCKERHUB_USER=            # 이미지 네임스페이스 (docker.io/<USER>/ros2-jazzy-yolo 등)
# DOCKERHUB_TOKEN=           # docker login 용 access token (publish 시, push 단계 host)
# YOLO_TAG=v0.1.0            # latest 금지 — semver / git SHA 만
# VOICE_TAG=v0.1.0
# CUDA_VERSION=12.8          # yolo 이미지 build-arg (pip cu128). 기본값은 resources/config.sh
# ROS_DOMAIN_ID=42           # host ↔ 컨테이너 DDS discovery 동일 도메인. 단일 진실 소스 = resources/config.sh(기본 42).
#                            # 비워두면 host·compose 둘 다 42 사용. 값을 바꾸려면 반드시 host·양 컨테이너 동일 — 다르면 조용한 discovery 실패

# === Installer Config ===
# ROS_DISTRO=jazzy
# UBUNTU_CODENAME=noble
# INSTALL_STATE_FILE=$HOME/.ros2_jazzy_test/state
