# Environment
.env
.env.local
# 음성 점검이 API 키를 기록하며 만드는 임시파일(.env.XXXXXX) 등 모든 .env 파생물 — 단 템플릿은 추적
.env.*
!.env.example

# Installer state / checkpoint — 머신별 진행 상태라 재생성 가능, 추적하지 않음
.install_state
*.state
/state/

# Logs (append-only, but not committed)
*.log
install.log
*.jsonl

# Downloaded artifacts / intermediate
*.deb
*.run
*.tar.gz
*.tgz
*.zip

# Python (Voice 단계 잔여물)
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*~

# Jupyter checkpoint shadow
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# 설치 스크립트와 무관한 작업 데이터 — 추적/배포 대상 아님.
# claude-migration: 세션 transcript(.jsonl) 등 민감 데이터 포함. corecode: 별도 튜토리얼.
claude-migration/
corecode/

# 이 브랜치(main)는 설치 스크립트 + 컨테이너 빌드 정의를 담는 배포 소스다.
# 개발 도구 / 내부 문서 / AI 작업 지침은 개발 브랜치에서만 추적한다.
# 여기서는 작업트리에 남겨두되 추적 제외.
.claude/
tasks/
docs/
CLAUDE.md

# jog 편의 복사본 — cobot2_ws 안의 원본과 byte-identical. 실기 jog 를 최상위 경로로
# 실행하려고 둔 것이라 디스크엔 남기되 추적만 제외(중복 drift 방지). 원본은 그대로 추적.
/jog_complete.py

# 코드 인덱스 — 소스에서 재생성 가능한 산출물이라 추적 제외.
.codegraph/

# 브레인스토밍/스펙 설계 산출물 (로컬 작업물 — 배포 대상 아님)
docs/superpowers/

# 로컬 에이전트/분석 도구 산출물 — 소스에서 재생성 가능, 배포 대상 아님.
.agents/
.understand-anything/

# Skill 매니저가 설치/관리하는 패키지 + lock — 재설치로 재생성 가능, 로컬 환경 전용.
.claude/skills/
skills-lock.json

# 로컬 참조용 wiki 덤프 — 설치 스크립트/배포와 무관(humble 보존 스크립트는 backup/ 안에서 계속 추적).
backup/llm_wiki/
