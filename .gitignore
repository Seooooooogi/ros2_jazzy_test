# Environment
.env
.env.local
# .env 키 기록 시 만드는 임시파일(.env.XXXXXX) 등 모든 .env 파생물 — 단 템플릿은 추적
.env.*
!.env.example

# Installer state / checkpoint — 머신별 진행 상태라 재생성 가능, 추적하지 않음
.install_state
*.state
/state/

# Logs (append-only, but not committed)
*.log
install.log
*.jsonl

# Downloaded artifacts / intermediate
*.deb
*.run
*.tar.gz
*.tgz
*.zip

# Python (Voice 단계 잔여물)
__pycache__/
*.pyc
*.pyo
venv/
.venv/

# IDE
.vscode/
.idea/
*.swp
*~

# Jupyter checkpoint shadow
.ipynb_checkpoints/

# OS
.DS_Store
Thumbs.db

# 설치 스크립트와 무관한 작업 데이터 — 추적/배포 대상 아님.
# claude-migration: 세션 transcript(.jsonl) 등 민감 데이터 포함. corecode: 별도 튜토리얼.
claude-migration/
corecode/

# jog 편의 복사본 — cobot2_ws/rokey/rokey/basic/jog_complete.py 와 byte-identical.
# 실기 jog 검증을 최상위 경로로 실행하려고 둔 것이라 디스크엔 남기되 추적만 제외(중복 drift 방지).
# 최상위만 anchor — cobot2_ws 안의 원본은 그대로 추적.
/jog_complete.py
