<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS 설정 템플릿. dds-tuning.sh 가 아래 인터페이스 placeholder 줄을 설치
  머신의 loopback + 물리 NIC(유선·무선) 목록으로 치환해 ${CYCLONEDDS_XML} (기본
  ~/.ros2_jazzy_test/cyclonedds.xml) 로 렌더한다. 렌더 결과는 머신 종속 산출물이라
  레포로 추적하지 않는다.

  [인터페이스] loopback(lo) + 물리 외부 NIC(유선·무선)를 함께 화이트리스트한다.
  같은 호스트 노드끼리(호스트 ↔ network_mode:host 컨테이너)는 cyclonedds 가 loopback
  을 우선 선택(priority 가 높음)해 127.0.0.1 로 주고받는다 — 외부 NIC 의 자기 IP 로
  unicast 를 보내다 실패하는 라우팅 이슈(예: 유선·무선이 같은 서브넷이면 커널이 자기
  IP 를 엉뚱한 인터페이스로 내보내 송신 실패)를 원천 회피한다. 외부 물리 NIC 는 다른
  머신과의 cross-host 통신 경로로 남기고 presence_required="false" 로 두어, 그 포트가
  down 이어도 노드 기동을 막지 않는다. docker/veth/가상 브리지는 타 머신 경로가 아니고
  쓸모없는 locator 만 늘리므로 제외한다.

  [버퍼] RealSense raw 같은 대용량 프레임(color ≈ 2.6MB)은 UDP fragment 로 쪼개져
  전송된다. DDS 요청 버퍼는 커널 net.core.rmem_max / wmem_max 에 캡되므로
  /etc/sysctl.d/60-cyclonedds.conf 와 반드시 세트로 적용해야 한다. 특히
  SocketSendBufferSize 는 하드 최소값이라 wmem_max 가 부족하면 도메인 생성이 거부된다.
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
__DDS_INTERFACES__
      </Interfaces>
      <!-- loopback 에서 SPDP discovery 가 동작하려면 멀티캐스트 허용이 필요. -->
      <AllowMulticast>true</AllowMulticast>
    </General>
    <Internal>
      <SocketReceiveBufferSize min="64MB"/>
      <SocketSendBufferSize min="64MB"/>
    </Internal>
  </Domain>
</CycloneDDS>
