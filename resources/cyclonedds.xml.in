<?xml version="1.0" encoding="UTF-8"?>
<!--
  CycloneDDS 설정 템플릿. dds-tuning.sh 가 아래 인터페이스 placeholder 줄을 설치
  머신의 물리 유선 NIC 목록으로 치환해 ${CYCLONEDDS_XML} (기본 ~/.ros2_jazzy_test/cyclonedds.xml)
  로 렌더한다. 렌더 결과는 머신 종속 산출물이라 레포로 추적하지 않는다.

  [인터페이스] 유선 NIC 만 화이트리스트하고 wifi/docker/가상 인터페이스는 제외한다.
  wifi 로 멀티캐스트가 새거나 무선 지연으로 토픽이 끊기는 것을 막는다. 유선 포트가
  여러 개면 전부 나열하고 presence_required="false" 로 두어, 로봇이 어느 포트에
  꽂히든(그 포트만 up) 그 인터페이스가 쓰이게 한다. 목록에 wifi 가 없으므로 어떤
  경우에도 wifi 로 fallback 하지 않는다(전부 down 이면 노드가 시끄럽게 실패).

  [버퍼] RealSense raw 같은 대용량 프레임(color ≈ 2.6MB)은 UDP fragment 로 쪼개져
  전송된다. DDS 요청 버퍼는 커널 net.core.rmem_max / wmem_max 에 캡되므로
  /etc/sysctl.d/60-cyclonedds.conf 와 반드시 세트로 적용해야 한다. 특히
  SocketSendBufferSize 는 하드 최소값이라 wmem_max 가 부족하면 도메인 생성이 거부된다.
-->
<CycloneDDS xmlns="https://cdds.io/config"
            xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
            xsi:schemaLocation="https://cdds.io/config https://raw.githubusercontent.com/eclipse-cyclonedds/cyclonedds/master/etc/cyclonedds.xsd">
  <Domain id="any">
    <General>
      <Interfaces>
__DDS_INTERFACES__
      </Interfaces>
    </General>
    <Internal>
      <SocketReceiveBufferSize min="64MB"/>
      <SocketSendBufferSize min="64MB"/>
    </Internal>
  </Domain>
</CycloneDDS>
